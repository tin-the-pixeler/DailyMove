---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'DailyMove Widget' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body style="background-color: #0a0a0f; color: #f0f0f0; margin: 0;">
    <slot />
  </body>
</html>
