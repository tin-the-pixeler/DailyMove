---
import '../styles/global.css';

interface Props {
  title?: string;
  streak?: number;
}

const { title = 'DailyMove', streak = 0 } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Daily exercise habit tracker" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body style="background-color: #0a0a0f; color: #f0f0f0;">
    <!-- Header -->
    <header style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background-color: #0a0a0f; border-bottom: 1px solid #1a1a1f; height: 56px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px;">
      <a href="/" style="text-decoration: none; font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em;">
        <span style="color: #f0f0f0;">daily</span><span style="color: #5DCAA5;">move</span>
      </a>
      <!-- Streak pill -->
      <div style="display: flex; align-items: center; gap: 6px; background-color: #151519; border-radius: 999px; padding: 6px 12px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5DCAA5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
        </svg>
        <span style="color: #5DCAA5; font-size: 0.875rem; font-weight: 600;">{streak} days</span>
      </div>
    </header>

    <!-- Main content with padding for fixed header and nav -->
    <main style="padding-top: 72px; padding-bottom: 80px; min-height: 100vh;">
      <slot />
    </main>

    <!-- Bottom nav -->
    <nav style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 50; background-color: #0a0a0f; border-top: 1px solid #1a1a1f; height: 64px; display: flex; align-items: center;">
      <a
        href="/"
        style={`flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; text-decoration: none; color: ${pathname === '/' ? '#5DCAA5' : '#444'}; font-size: 0.75rem; font-weight: 500;`}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Today
      </a>
      <a
        href="/history"
        style={`flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; text-decoration: none; color: ${pathname === '/history' ? '#5DCAA5' : '#444'}; font-size: 0.75rem; font-weight: 500;`}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" x2="18" y1="20" y2="10"/>
          <line x1="12" x2="12" y1="20" y2="4"/>
          <line x1="6" x2="6" y1="20" y2="14"/>
        </svg>
        History
      </a>
    </nav>
  </body>
</html>
