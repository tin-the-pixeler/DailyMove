---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getUser } from '../lib/supabase-server';

const user = await getUser(Astro.cookies);
if (!user) return Astro.redirect('/login');
---

<BaseLayout title="DailyMove – Today">
  <div style="display: flex; align-items: center; justify-content: center; height: 60vh; color: #555; font-size: 1rem;">
    Today's exercise — coming soon
  </div>
</BaseLayout>
